MONGO_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=

MONGO_EXPRESS_USERNAME=admin
MONGO_EXPRESS_PASSWORD=

DB_NAME=sustainable_meal_planner

READWRITE_USERNAME=readwrite
READWRITE_PASSWORD=

READONLY_USERNAME=readonly
READONLY_PASSWORD=

# How often the scraper runs (in minutes)
SCRAPE_INTERVAL_MINUTES=5

# Anthropic API key for Claude-based recipe extraction
ANTHROPIC_API_KEY=
# Alternative name also accepted:
# CLAUDE_API_KEY=

# Optional: if set, scraped recipes are also written as JSON files to this directory
# RECIPES_OUTPUT_DIR=/tmp/recipes
